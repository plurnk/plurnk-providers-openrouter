# OpenRouter relay config.
# Override order: .env < .env.<profile> < shell.

# --- Endpoint ---
# Base URL of OpenRouter's API. Trailing /v1 or /v1/ is stripped.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Auth ---
# Bearer token from openrouter.ai/keys. Required.
OPENROUTER_API_KEY=

# --- Timeouts ---
# Fetch timeout in ms. Streamed completions can run long; default 10 minutes.
OPENROUTER_FETCH_TIMEOUT_MS=600000

# --- Ranking headers ---
# OpenRouter uses these to attribute traffic on the public model rankings.
# Leave empty to opt out. The values are sent as `HTTP-Referer` and
# `X-Title` request headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=
