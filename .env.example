# OpenRouter relay config.
# Override order: .env < .env.<profile> < shell.

# Bearer token from openrouter.ai/keys. Required.
OPENROUTER_API_KEY=

# Optional: override the API root (tunnels, proxies, replays). The default
# is https://openrouter.ai/api/v1 and there is no second canonical location.
# OPENROUTER_BASE_URL=

# Optional: ranking-header attribution on openrouter.ai's public model
# rankings. Leave unset to opt out.
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=

# Note: fetch timeout is the universal PLURNK_PROVIDERS_FETCH_TIMEOUT
# (set in plurnk-service's env), not a per-provider knob.
